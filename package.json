{
  "name": "npi-website",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "supabase": "supabase",
    "supabase:link": "supabase link",
    "supabase:migrations": "supabase migration list --db-url \"$SUPABASE_DB_URL\"",
    "supabase:pull": "supabase db pull --db-url \"$SUPABASE_DB_URL\"",
    "supabase:push": "supabase db push --db-url \"$SUPABASE_DB_URL\"",
    "supabase:types": "supabase gen types --project-id \"$SUPABASE_PROJECT_REF\" --lang typescript --schema public > src/types/database.ts"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@supabase/supabase-js": "2.49.1",
    "@tabler/icons-react": "^3.40.0",
    "clsx": "^2.1.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^6.28.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "supabase": "^2.79.0",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^5.4.19"
  }
}
